<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Flutter hot-reload VM service -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Model downloads from HuggingFace, audio URL fetches -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Microphone for the in-app recorder -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- User-selected file access (file_picker + drag-and-drop) -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>com.apple.security.files.downloads.read-only</key>
	<true/>
	<!-- Load unsigned dylibs so users can drop a custom libwhisper.dylib -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
