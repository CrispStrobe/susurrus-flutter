<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Group identifier shared with the main Runner app.
         The Share Extension writes inbound files into the
         shared container under this group; the main app reads
         them back via receive_sharing_intent on next launch /
         resume. Must match Runner/Runner.entitlements. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.crispstrobe.crisperweaver</string>
    </array>
</dict>
</plist>
