	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.susurrus.flutter</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>susurrus</string>
			</array>
			<key>CFBundleURLIconFile</key>
			<string></string>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.susurrus.flutter.audio</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>susurrus-audio</string>
			</array>
		</dict>
	</array>

